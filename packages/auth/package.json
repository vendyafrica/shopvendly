{
  "name": "@shopvendly/auth",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/auth-client.d.ts",
      "import": "./dist/auth-client.js",
      "require": "./dist/auth-client.cjs",
      "default": "./dist/auth-client.js"
    },
    "./server": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js",
      "require": "./dist/auth.cjs",
      "default": "./dist/auth.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js",
      "require": "./dist/auth.cjs",
      "default": "./dist/auth.js"
    },
    "./auth-client": {
      "types": "./dist/auth-client.d.ts",
      "import": "./dist/auth-client.js",
      "require": "./dist/auth-client.cjs",
      "default": "./dist/auth-client.js"
    },
    "./react": {
      "types": "./dist/auth-client.d.ts",
      "import": "./dist/auth-client.js",
      "require": "./dist/auth-client.cjs",
      "default": "./dist/auth-client.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@types/node": "^22.15.3",
    "@shopvendly/db": "workspace:*",
    "@shopvendly/transactional": "workspace:*",
    "better-auth": "^1.4.10",
    "dotenv": "^17.2.3",
    "tsup": "^8.5.0",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@shopvendly/eslint-config": "workspace:*",
    "@shopvendly/typescript-config": "workspace:*",
    "eslint": "^9.39.0"
  }
}