{
  "extends": "../../packages/typescript-config/nextjs.json",
  "exclude": [
    "node_modules"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "outDir": "dist",
    "types": [
      "node"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@shopvendly/ui/globals.css": [
        "../../packages/ui/src/styles/globals.css"
      ],
      "@shopvendly/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@shopvendly/db": [
        "../../packages/db/src/index.ts"
      ],
      "@shopvendly/db/*": [
        "../../packages/db/src/*"
      ],
      "@shopvendly/auth": [
        "../../packages/auth/src/index.ts"
      ],
      "@shopvendly/auth/client": [
        "../../packages/auth/src/auth-client.ts"
      ],
      "@shopvendly/auth/auth-client": [
        "../../packages/auth/src/auth-client.ts"
      ],
      "@shopvendly/db/db": [
        "../../packages/db/src/db.ts"
      ],
      "@shopvendly/db/schema": [
        "../../packages/db/src/schema/index.ts"
      ],
      "@shopvendly/auth/react": [
        "../../packages/auth/src/auth-client.ts"
      ],
      "@shopvendly/transactional": [
        "../../packages/transactional/dist/index.js"
      ],
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src",
    "app",
    "../../packages/ui/src",
    "../../packages/db/src",
    "../../packages/auth/dist",
    "../../packages/transactional/dist",
    "next.config.ts",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ]
}