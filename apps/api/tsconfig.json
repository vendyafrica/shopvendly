{
  "extends": "../../packages/typescript-config/base.json",
  "compilerOptions": {
    "lib": [
      "ES2015"
    ],
    "outDir": "./dist",
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@shopvendly/db": [
        "../../packages/db/dist/index"
      ],
      "@shopvendly/db/db": [
        "../../packages/db/dist/db"
      ],
      "@shopvendly/db/schema": [
        "../../packages/db/dist/schema/index.js"
      ],
      "@shopvendly/auth": [
        "../../packages/auth/dist/index.js"
      ],
      "@shopvendly/auth/auth-client": [
        "../../packages/auth/dist/auth-client.js"
      ],
      "@shopvendly/transactional": [
        "../../packages/transactional/dist/index.js"
      ]
    }
  },
  "exclude": [
    "node_modules"
  ],
  "include": [
    ".",
    "../../packages/db/drizzle.config.ts",
    "../../packages/db/src/seed"
  ]
}