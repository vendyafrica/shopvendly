{
  "extends": "../../packages/typescript-config/nextjs.json",
  "exclude": [
    "node_modules"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "outDir": "dist",
    "plugins": [
      {
        "name": "@shopvendly/web"
      }
    ],
    "paths": {
      "@shopvendly/ui/globals.css": [
        "../../packages/ui/src/styles/globals.css"
      ],
      "@/src/*": [
        "../../packages/ui/src/*"
      ],
      "@shopvendly/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@shopvendly/db": [
        "../../packages/db/src/index.ts"
      ],
      "@shopvendly/auth": [
        "../../packages/auth/dist/index.js"
      ],
      "@shopvendly/auth/auth-client": [
        "../../packages/auth/dist/auth-client.js"
      ],
      "@shopvendly/db/db": [
        "../../packages/db/src/db.ts"
      ],
      "@shopvendly/db/schema": [
        "../../packages/db/src/schema/index.ts"
      ],
      "@shopvendly/auth/react": [
        "../../packages/auth/dist/auth-client.js"
      ],
      "@shopvendly/transactional": [
        "../../packages/transactional/dist/index.js"
      ],
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "app",
    "actions",
    "repo",
    "models",
    "modules",
    "shared",
    "providers",
    "features",
    "components",
    "hooks",
    "lib",
    "utils",
    "data",
    "types",
    "contexts",
    "../../packages/ui/src",
    "../../packages/db/src",
    "../../packages/auth/src",
    "../../packages/transactional",
    "next.config.ts",
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "proxy.ts"
  ]
}
