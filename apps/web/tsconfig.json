{
  "extends": "../../packages/typescript-config/nextjs.json",
  "exclude": [
    "node_modules"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "outDir": "dist",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@shopvendly/ui/globals.css": [
        "../../packages/ui/src/styles/globals.css"
      ],
      "@/src/*": [
        "../../packages/ui/src/*"
      ],
      "@shopvendly/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@shopvendly/db": [
        "../../packages/db/src/index.ts"
      ],
      "@shopvendly/auth": [
        "../../packages/auth/src/index.ts"
      ],
      "@shopvendly/auth/auth-client": [
        "../../packages/auth/src/auth-client.ts"
      ],
      "@vendly/db/db": [
        "../../packages/db/src/db.ts"
      ],
      "@vendly/db/schema": [
        "../../packages/db/src/schema/index.ts"
      ],
      "@vendly/auth/react": [
        "../../packages/auth/src/auth-client.ts"
      ],
      "@vendly/transactional": [
        "../../packages/transactional/index.ts"
      ],
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src",
    "../../packages/ui/src",
    "../../packages/db/src",
    "../../packages/auth/src",
    "../../packages/transactional",
    "next.config.ts",
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "proxy.ts"
  ]
}