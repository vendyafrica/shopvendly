{
  "name": "my-turborepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "web": "pnpm --filter @shopvendly/web dev",
    "admin": "pnpm --filter @shopvendly/admin dev",
    "api": "pnpm --filter @shopvendly/api dev",
    "generate": "pnpm --filter @shopvendly/db run generate",
    "push": "pnpm --filter @shopvendly/db run push"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.11",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.19.12"
    }
  },
  "dependencies": {
    "@react-email/components": "1.0.1",
    "@types/recharts": "^2.0.1",
    "recharts": "^2.15.4"
  }
}